<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="industrial_arm">

    <material name="industrial_orange">
        <color rgba="1.0 0.4 0.0 1.0"/>
    </material>
    <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
    </material>

    <link name="world"/>

    <joint name="virtual_joint" type="fixed">
        <parent link="world"/>
        <child link="base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="base_link">
        <visual>
            <geometry>
                <cylinder radius="0.2" length="0.1"/>
            </geometry>
            <material name="dark_grey"/>
        </visual>
        <collision>
            <geometry> <cylinder radius="0.2" length="0.1"/> </geometry>
        </collision>
        <inertial>
            <mass value="10.0"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="0.108" ixy="0.0" ixz="0.0" iyy="0.108" iyz="0.0" izz="0.2"/>
        </inertial>
    </link>

    <joint name="joint_1" type="revolute">
        <parent link="base_link"/>
        <child link="link_1"/>
        <origin xyz="0 0 0.05" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14" upper="3.14" effort="100.0" velocity="2.0"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="link_1">
        <visual>
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.15" length="0.2"/>
            </geometry>
            <material name="industrial_orange"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
            <geometry><cylinder radius="0.15" length="0.2"/></geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
            <mass value="5.0"/>
            <inertia ixx="0.044" ixy="0.0" ixz="0.0" iyy="0.044" iyz="0.0" izz="0.056"/>
        </inertial>
    </link>

    <joint name="joint_2" type="revolute">
        <parent link="link_1"/>
        <child link="link_2"/>
        <origin xyz="0 0 0.2" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-1.57" upper="1.57" effort="150.0" velocity="1.5"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="link_2">
        <visual>
            <origin xyz="0 0 0.25" rpy="0 0 0"/>
            <geometry>
                <box size="0.1 0.1 0.5"/>
            </geometry>
            <material name="dark_grey"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.25" rpy="0 0 0"/>
            <geometry><box size="0.1 0.1 0.5"/></geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.25" rpy="0 0 0"/>
            <mass value="4.0"/>
            <inertia ixx="0.086" ixy="0.0" ixz="0.0" iyy="0.086" iyz="0.0" izz="0.006"/>
        </inertial>
    </link>

    <ros2_control name="GazeboSimSystem" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>
        
        <joint name="joint_1">
            <command_interface name="position">
                <param name="min">-3.14</param>
                <param name="max">3.14</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="joint_2">
            <command_interface name="position">
                <param name="min">-1.57</param>
                <param name="max">1.57</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
    </ros2_control>

    <gazebo>
        <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters>$(find industrial_arm_description)/config/arm_controllers.yaml</parameters>
        </plugin>
    </gazebo>

</robot>
